{
    "name": "renocms/forms",
    "description": "Forms package Reno CMS",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Reno CMS Team",
            "email": "contacts@renocms.ru"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "reno/cms": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Reno\\Forms\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Reno\\Forms\\FormsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
